{
  "name": "defcode",
  "displayName": "Defcode",
  "description": "AI-powered coding assistant — open Defcode CLI as a tab in your editor",
  "version": "0.0.1",
  "publisher": "defcode",
  "license": "MIT",
  "engines": {
    "vscode": "^1.85.0"
  },
  "categories": ["AI", "Programming Languages", "Other"],
  "keywords": ["ai", "coding", "assistant", "defcode", "cli"],
  "activationEvents": ["onStartupFinished"],
  "main": "./out/extension.js",
  "icon": "icon.png",
  "contributes": {
    "commands": [
      {
        "command": "defcode.open",
        "title": "Defcode: Open"
      },
      {
        "command": "defcode.openInTab",
        "title": "Defcode: Open in Editor Tab"
      }
    ],
    "keybindings": [
      {
        "command": "defcode.open",
        "key": "ctrl+shift+d",
        "mac": "cmd+shift+d"
      }
    ]
  },
  "scripts": {
    "dev": "tsc -w -p tsconfig.json",
    "build": "tsc -p tsconfig.json",
    "package": "npm run build && vsce package"
  },
  "devDependencies": {
    "@types/vscode": "^1.85.0",
    "typescript": "^5.4.0"
  }
}
